<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="map_path"/>
  <arg name="launch_vehicle" default="true"/>
  <arg name="launch_sensing" default="true"/>

  <!-- include first for global parameters  -->
  <group scoped="false">
    <include file="$(find-pkg-share autoware_core)/launch/autoware_core.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
      <arg name="map_path" value="$(var map_path)"/>
      <arg name="vehicle_info_param_file" value="$(find-pkg-share autoware_sample_platform_launch)/config/vehicle_info.param.yaml"/>
    </include>
  </group>

  <!-- vehicle -->
  <group if="$(var launch_vehicle)">
    <include file="$(find-pkg-share autoware_sample_platform_launch)/launch/vehicle.launch.xml"/>
  </group>

  <!-- sensing -->
  <group if="$(var launch_sensing)">
    <include file="$(find-pkg-share autoware_sample_platform_launch)/launch/sensing.launch.xml"/>
  </group>

  <!-- robot description -->
  <group>
    <node name="robot_state_publisher" pkg="robot_state_publisher" exec="robot_state_publisher">
      <param name="robot_description" value="$(command 'xacro $(find-pkg-share autoware_sample_platform_launch)/description/platform/urdf/platform.xacro' 'warn')"/>
    </node>
  </group>
</launch>
