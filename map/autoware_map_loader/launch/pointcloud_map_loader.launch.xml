<launch>
  <arg name="pointcloud_map_path"/>
  <arg name="pointcloud_map_metadata_path"/>
  <arg name="pointcloud_map_loader_param_path" default="$(find-pkg-share autoware_map_loader)/config/pointcloud_map_loader.param.yaml"/>
  <arg name="enable_differential_pointcloud_map_visualizer" default="false"/>
  <arg name="differential_pointcloud_map_visualizer_param_path" default="$(find-pkg-share autoware_map_loader)/config/differential_pointcloud_map_visualizer.param.yaml"/>

  <node pkg="autoware_map_loader" exec="autoware_pointcloud_map_loader" name="pointcloud_map_loader" output="both">
    <remap from="output/pointcloud_map" to="/map/pointcloud_map"/>
    <remap from="service/get_partial_pcd_map" to="/map/get_partial_pointcloud_map"/>
    <remap from="service/get_differential_pcd_map" to="/map/get_differential_pointcloud_map"/>
    <remap from="service/get_selected_pcd_map" to="/map/get_selected_pointcloud_map"/>
    <param from="$(var pointcloud_map_loader_param_path)" allow_substs="true"/>
  </node>

  <node if="$(var enable_differential_pointcloud_map_visualizer)" pkg="autoware_map_loader" exec="autoware_differential_pointcloud_map_visualizer" name="differential_pointcloud_map_visualizer" output="both">
    <param from="$(var differential_pointcloud_map_visualizer_param_path)" allow_substs="true"/>
    <remap from="output/differential_pointcloud_map" to="/map/differential_pointcloud_map"/>
  </node>
</launch>
